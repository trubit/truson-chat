{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist/server",
    "rootDir": ".",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@server/*": ["./src/server/*"]
    }
  },
  "include": ["src/server", "src/shared", "src/types"],
  "exclude": [
    "node_modules",
    "dist",
    "src/client",
    "**/__tests__/**",
    "**/test-utils/**",
    "**/*.test.ts"
  ]
}
