{
  "name": "linkora",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Production real-time communication platform — WhatsApp, Telegram, Discord, Slack in one.",
  "scripts": {
    "dev": "concurrently -n SERVER,CLIENT -c cyan.bold,magenta.bold \"npm run server:dev\" \"npm run client:dev\"",
    "client:dev": "vite",
    "server:dev": "nodemon",
    "build": "npm run server:build && npm run client:build",
    "client:build": "vite build",
    "server:build": "tsc -p tsconfig.server.json",
    "start": "node dist/server/src/server/app.js",
    "typecheck": "tsc -b",
    "typecheck:client": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns='integration|e2e'",
    "test:e2e": "playwright test",
    "test:coverage": "jest --coverage",
    "db:seed": "tsx src/server/database/seed.ts",
    "db:migrate": "tsx src/server/database/migrate.ts",
    "prepare": "husky || true",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-query-devtools": "^5.101.1",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "bootstrap": "^5.3.8",
    "bullmq": "^5.79.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.0",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "dayjs": "^1.11.13",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.3",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^5.0.0",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.7",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.80.0",
    "react-hot-toast": "^2.6.0",
    "react-image-crop": "^11.0.7",
    "react-player": "^2.16.0",
    "react-router-dom": "^7.18.0",
    "react-virtuoso": "^4.18.9",
    "recharts": "^3.9.1",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.35.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^14.0.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.1",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.13.2",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.13.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^17.0.8",
    "mongodb-memory-server": "^10.1.4",
    "msw": "^2.7.5",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
